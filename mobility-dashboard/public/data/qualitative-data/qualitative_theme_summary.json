      "quotes": [
        {
          "text": "Linien die Regensburg umranden, sodass man nicht erstmal zum hbf fahren muss um vom Umkreis rgb (beispielsweise Tegernheim) zur uni zu kommen",
          "sourceField": "feedback_opnv",
          "sourceFieldLabel": "ÖPNV: Verbesserungswünsche",
          "statusGroup": "student",
          "statusGroupLabel": "Studierende"
        },
        {
          "text": "Die Zuverlässigkeit ist hauptsächlich zu Stoßzeiten (~8:00 und ~17:00) ein Problem während die Taktung vormittags nach 9:00 zu langsam ist.",
          "sourceField": "feedback_opnv",
          "sourceFieldLabel": "ÖPNV: Verbesserungswünsche",
          "statusGroup": "employee",
          "statusGroupLabel": "Mitarbeitende"
        },
        {
          "text": "An den RVV: der 5er fährt offiziell bis zur Schwaenstraße. Bleibt aber in der realität am Jahnstadion und schmeißt da alle raus. Eine Sauerei",
          "sourceField": "feedback_opnv",
          "sourceFieldLabel": "ÖPNV: Verbesserungswünsche",
          "statusGroup": "student",
          "statusGroupLabel": "Studierende"
        }
      ]
