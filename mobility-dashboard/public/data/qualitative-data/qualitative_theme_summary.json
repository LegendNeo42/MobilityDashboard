      "quotes": [
        {
          "text": "Ein Leihradsystem in Regensburg wäre großartig! Ich habe damit an meinem vorherigen Studienort (Lüneburg) hervorragende Erfahrungen gemacht!",
          "sourceField": "feedback_bicycle",
          "sourceFieldLabel": "Fahrrad: allgemeine Hinweise",
          "statusGroup": "student",
          "statusGroupLabel": "Studierende"
        },
        {
          "text": "Wie bereits 5 mal erwähnt: Fahrrad ist in Rgbg einfach am besten, wäre klasse wenn da weiter an den Möglichkeiten gearbeitet werden könnte",
          "sourceField": "feedback_bicycle",
          "sourceFieldLabel": "Fahrrad: allgemeine Hinweise",
          "statusGroup": "student",
          "statusGroupLabel": "Studierende"
        },
        {
          "text": "Fahrradstellplatzsituation ist mangelhaft. Sichere, moderne Fahrradstellplätze, an denen das Fahrrad vor Diebstahl und Wetter geschützt ist.",
          "sourceField": "feedback_bicycle_campus",
          "sourceFieldLabel": "Fahrrad am Campus",
          "statusGroup": "employee",
          "statusGroupLabel": "Mitarbeitende"
        }
      ]
